# Health OS — локальные настройки
# Скопируй: cp .env.example .env
# Меняй пароли перед запуском в "более серьёзном" режиме.

# Postgres
POSTGRES_DB=healthos
POSTGRES_USER=healthos
POSTGRES_PASSWORD=changeme_local
POSTGRES_PORT=5432
FHIR_DB=fhir

# MinIO
MINIO_ROOT_USER=healthos
MINIO_ROOT_PASSWORD=changeme_local
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# HAPI FHIR
FHIR_PORT=8080

# Backend
BACKEND_PORT=8000

# Web UI
WEB_PORT=3000

# Ollama (только при --profile ai)
OLLAMA_PORT=11434
