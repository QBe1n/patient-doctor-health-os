# Скопируй в .env: cp .env.example .env
# Используется Docker Compose как дефолты для некоторых env-подстановок.
# Секреты живут в ./secrets/ (см. ниже), не здесь.

# Часовой пояс (влияет на логи и timestamp в HAPI)
TZ=Europe/Moscow

# Профиль моделей Ollama: lite | base | heavy
OLLAMA_PROFILE=base

# Версии образов (фиксируем для воспроизводимости — обнови когда будешь готов)
HAPI_IMAGE=hapiproject/hapi:latest
POSTGRES_IMAGE=pgvector/pgvector:pg16
MINIO_IMAGE=minio/minio:latest
OLLAMA_IMAGE=ollama/ollama:latest
